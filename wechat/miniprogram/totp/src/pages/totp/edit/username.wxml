<t-toast id="t-toast" />
<t-message id="t-message" />

<view class="page">
  <form bindsubmit="submit">
    <view class="section">
      <view class="section-label">账号名称</view>
      <view class="input-card">
        <t-input name="username" placeholder="请填写账号" value="{{username}}" maxlength="64" align="left" borderless />
      </view>
      <view class="section-hint">例如：user@example.com、手机号等</view>
    </view>

    <view class="actions">
      <t-button theme="primary" size="large" type="submit" block>保存</t-button>
      <t-button size="large" variant="outline" bind:tap="cancel" block>取消</t-button>
    </view>
  </form>
</view>
